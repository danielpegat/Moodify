# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Spotify Developer Dashboard → app → Client ID
# Redirect URI must match exactly: {VITE_APP_URL}/auth/callback
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# Public URL of this app (no trailing slash). Example: http://localhost:5173
VITE_APP_URL=http://localhost:5173

# If Spotify rejects "localhost" and you only use 127.0.0.1, set this to match Dashboard exactly:
# VITE_SPOTIFY_REDIRECT_ORIGIN=http://127.0.0.1:5173

# Optional: override Edge Functions base (defaults to {VITE_SUPABASE_URL}/functions/v1/spotify-api)
# VITE_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT.supabase.co/functions/v1/spotify-api
